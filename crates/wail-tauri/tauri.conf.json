{
  "productName": "WAIL",
  "version": "0.2.0",
  "identifier": "com.wail.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WAIL",
        "width": 480,
        "height": 640,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
